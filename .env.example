# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Attio CRM (default provider)
CRM_PROVIDER=attio
CRM_API_KEY=your-attio-api-token
CRM_BASE_URL=https://api.attio.com/v2

# Attio attribute slugs — adjust to match your workspace schema
CRM_PERSON_LINKEDIN_ATTR=linkedin
CRM_DEAL_STAGE_ATTR=stage
CRM_DEAL_SOURCE_ATTR=source
CRM_DEAL_SOURCE_TYPE=select
CRM_DEAL_OWNER_ATTR=owner
CRM_DEAL_LAST_REMINDER_ATTR=last_reminder_day
CRM_DEAL_STAGE_INTERESTED=Lead Interested
CRM_DEAL_SOURCE_LINKEDIN=Cold LinkedIn
CRM_ATTRIBUTION_LIST_SLUG=linkedin-attribution
CRM_DEAL_OWNER_RECORD_ID=

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_ERROR_WEBHOOK_URL=

# HeyReach webhook security (optional — set if you configure a shared secret)
HEYREACH_WEBHOOK_SECRET=

# HeyReach API key (optional). If set, the dashboard "Send reply" button posts
# the approved message back to the lead via HeyReach's SendMessage API.
# Without it, approved replies are pushed to Slack so a human can copy/paste.
HEYREACH_API_KEY=

# Storage for the review dashboard (optional but recommended in prod).
# Either set Vercel KV vars (auto-injected when you add Vercel KV / Upstash),
# or leave blank and the store falls back to a local JSON file in /tmp
# (ephemeral on Vercel — fine for testing, not for production).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel cron auth (set in Vercel dashboard; Vercel sends Authorization: Bearer <value>)
CRON_SECRET=
