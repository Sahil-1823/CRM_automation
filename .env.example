# Single admin dashboard (one password — set in Vercel, no user accounts)
ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional display name for the admin session (default: admin)
ADMIN_USERNAME=admin
# Optional — extra secret for signing session cookies (defaults to ADMIN_PASSWORD)
AUTH_SECRET=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# HeyReach — inbound webhooks and outbound replies (required)
HEYREACH_API_KEY=your-heyreach-api-key
HEYREACH_WEBHOOK_SECRET=
HEYREACH_API_BASE_URL=

# Upstash Redis (required for inbox + document index)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector (recommended for RAG — faster retrieval at scale)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Legacy Vercel KV names (also supported for Redis)
KV_REST_API_URL=
KV_REST_API_TOKEN=
